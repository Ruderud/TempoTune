{
  "name": "mobile",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/mobile/src",
  "projectType": "application",
  "tags": ["type:app", "platform:mobile"],
  "targets": {
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @tempo-tune/mobile start",
        "cwd": "apps/mobile"
      }
    },
    "android": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @tempo-tune/mobile android",
        "cwd": "apps/mobile"
      }
    },
    "ios": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @tempo-tune/mobile ios",
        "cwd": "apps/mobile"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @tempo-tune/mobile lint",
        "cwd": "apps/mobile"
      }
    },
    "type-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @tempo-tune/mobile type-check",
        "cwd": "apps/mobile"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @tempo-tune/mobile test",
        "cwd": "apps/mobile"
      }
    },
    "e2e-device": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx ../../scripts/qa/run-appium.ts",
        "cwd": "apps/mobile"
      }
    },
    "e2e-device-ios-sim": {
      "executor": "nx:run-commands",
      "options": {
        "command": "QA_PLATFORM=ios QA_DEVICE_MODE=booted QA_IOS_BUNDLE_ID=com.rud.tempotune tsx ../../scripts/qa/run-appium.ts",
        "cwd": "apps/mobile"
      }
    },
    "e2e-device-ios-real": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx ../../scripts/qa/run-ios-real-device.ts",
        "cwd": "apps/mobile"
      }
    },
    "e2e-device-discover": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx ../../scripts/qa/discover-mobile-targets.ts",
        "cwd": "apps/mobile"
      }
    },
    "e2e-device-preflight": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx ../../scripts/qa/check-mobile-preflight.ts",
        "cwd": "apps/mobile"
      }
    },
    "e2e-device-preflight-ios-sim": {
      "executor": "nx:run-commands",
      "options": {
        "command": "QA_PLATFORM=ios QA_DEVICE_MODE=booted QA_REQUIRED_APPIUM_DRIVERS=xcuitest tsx ../../scripts/qa/check-mobile-preflight.ts",
        "cwd": "apps/mobile"
      }
    },
    "e2e-device-preflight-ios-real": {
      "executor": "nx:run-commands",
      "options": {
        "command": "QA_PLATFORM=ios QA_DEVICE_MODE=connected QA_REQUIRED_APPIUM_DRIVERS=xcuitest tsx ../../scripts/qa/check-mobile-preflight.ts",
        "cwd": "apps/mobile"
      }
    },
    "e2e-device-bootstrap": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx ../../scripts/qa/bootstrap-device-run.ts",
        "cwd": "apps/mobile"
      }
    },
    "e2e-device-prepare-ios-sim": {
      "executor": "nx:run-commands",
      "options": {
        "command": "QA_PLATFORM=ios QA_DEVICE_MODE=booted QA_IOS_BUNDLE_ID=com.rud.tempotune tsx ../../scripts/qa/prepare-ios-simulator-app.ts",
        "cwd": "apps/mobile"
      }
    },
    "e2e-device-setup": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx ../../scripts/qa/setup-appium-drivers.ts",
        "cwd": "apps/mobile"
      }
    },
    "e2e-device-setup-ios-sim": {
      "executor": "nx:run-commands",
      "options": {
        "command": "QA_PLATFORM=ios tsx ../../scripts/qa/setup-appium-drivers.ts",
        "cwd": "apps/mobile"
      }
    },
    "e2e-device-setup-ios-real": {
      "executor": "nx:run-commands",
      "options": {
        "command": "QA_PLATFORM=ios tsx ../../scripts/qa/setup-appium-drivers.ts",
        "cwd": "apps/mobile"
      }
    }
  }
}
