# Production web URL
PROD_WEB_URL=https://your-production-url.com

# Dev server port (used with auto-detected IP)
DEV_SERVER_PORT=3000

# Android emulator loopback IP (usually no need to change)
ANDROID_EMULATOR_HOST=10.0.2.2

# Optional: use the dev web server from release-style QA builds
QA_USE_DEV_WEB_URL=0

# Optional: enable WebView debugging/banner in QA builds
QA_ENABLE_WEBVIEW_DEBUGGING=0

# Optional: override WebView URL for real-device QA
QA_WEB_URL=
