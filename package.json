{
  "name": "@tempo-tune/monorepo",
  "version": "0.1.0",
  "description": "메트로놈과 기타/베이스 튜너 기능을 제공하는 하이브리드 모바일 앱",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "nx run-many --target=serve --all --parallel",
    "build": "nx run-many --target=build --all",
    "test": "nx run-many --target=test --all",
    "lint": "nx run-many --target=lint --all",
    "type-check": "nx run-many --target=type-check --all",
    "check:ui-quality": "bash scripts/check-ui-quality.sh",
    "clean": "nx reset && nx run-many --target=clean --all",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "husky",
    "qa": "pnpm exec nx run-many -t type-check lint test && tsx scripts/qa/validate-feature-docs.ts && tsx scripts/qa/check-regression.ts",
    "qa:affected": "pnpm exec nx affected -t type-check lint test && tsx scripts/qa/validate-feature-docs.ts && tsx scripts/qa/check-regression.ts",
    "qa:web": "pnpm run qa && pnpm exec nx run web:e2e",
    "qa:audio-fixtures": "node scripts/qa/generate-audio-fixtures.mjs",
    "qa:ondevice": "tsx scripts/qa/run-ondevice-check.ts",
    "qa:ondevice:list": "tsx scripts/qa/run-ondevice-check.ts --list",
    "qa:device": "tsx scripts/qa/check-mobile-preflight.ts && tsx scripts/qa/bootstrap-device-run.ts && tsx scripts/qa/run-appium.ts",
    "qa:device:android-emu": "tsx scripts/qa/run-android-emulator.ts",
    "qa:device:android-real": "tsx scripts/qa/run-android-real-device.ts",
    "qa:device:ios-sim": "tsx scripts/qa/run-ios-simulator.ts",
    "qa:device:ios-real": "tsx scripts/qa/run-ios-real-device.ts",
    "qa:device:audio-samples:android-emu": "tsx scripts/qa/run-android-emulator.ts --spec appium/specs/tuner-audio-input.smoke.spec.ts --spec appium/specs/rhythm-audio-sample.smoke.spec.ts",
    "qa:device:audio-samples:android-real": "tsx scripts/qa/run-android-real-device.ts --spec appium/specs/tuner-audio-input.smoke.spec.ts --spec appium/specs/rhythm-audio-sample.smoke.spec.ts",
    "qa:device:audio-samples:ios-sim": "tsx scripts/qa/run-ios-simulator.ts --spec appium/specs/tuner-audio-input.smoke.spec.ts --spec appium/specs/rhythm-audio-sample.smoke.spec.ts",
    "qa:device:audio-samples:ios-real": "tsx scripts/qa/run-ios-real-device.ts --spec appium/specs/tuner-audio-input.smoke.spec.ts --spec appium/specs/rhythm-audio-sample.smoke.spec.ts",
    "qa:full": "tsx scripts/qa/run-full-check.ts",
    "qa:setup:web": "pnpm --filter @tempo-tune/web exec playwright install --with-deps",
    "qa:setup:device": "tsx scripts/qa/setup-appium-drivers.ts",
    "qa:setup:device:android-emu": "QA_PLATFORM=android tsx scripts/qa/setup-appium-drivers.ts",
    "qa:setup:device:android-real": "QA_PLATFORM=android tsx scripts/qa/setup-appium-drivers.ts",
    "qa:setup:device:ios-sim": "QA_PLATFORM=ios tsx scripts/qa/setup-appium-drivers.ts",
    "qa:setup:device:ios-real": "QA_PLATFORM=ios tsx scripts/qa/setup-appium-drivers.ts"
  },
  "keywords": [
    "metronome",
    "tuner",
    "guitar",
    "bass",
    "react-native",
    "nextjs",
    "hybrid-app",
    "mobile-app"
  ],
  "author": "",
  "license": "MIT",
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.10"
    }
  },
  "engines": {
    "node": "^24.0.0",
    "pnpm": ">=10.0.0"
  },
  "devDependencies": {
    "@nx/eslint": "^22.4.0",
    "@nx/workspace": "^22.4.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "glob": "^11.0.0",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "lamejsfix": "^1.0.1",
    "minimatch": "^10.0.0",
    "nx": "^22.4.0",
    "prettier": "^3.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0"
  }
}
